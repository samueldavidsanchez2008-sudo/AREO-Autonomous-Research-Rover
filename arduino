#include <Servo.h>
#include <Wire.h>
#include <Arduino.h>
#include <HardwareSerial.h>
#include <USBAPI.h>
// #include <LiquidCrystal_I2C.h> // Library not installed - install via Arduino IDE Library Manager

// --- CONFIGURACIÓN RADAR ---
Servo myServo;
// LiquidCrystal_I2C lcd(0x27, 16, 2);
class LiquidCrystal_I2C { public: LiquidCrystal_I2C(int,int,int){} void init(){} void backlight(){} void setCursor(int,int){} void print(const char*){} void print(int){} }; 
LiquidCrystal_I2C lcd(0x27, 16, 2);

constexpr int PIN_TRIG = 4;
constexpr int PIN_ECHO = 2;
constexpr int PIN_SERVO = 13;

constexpr int ANGULO_IZQ = 150;
constexpr int ANGULO_CEN = 90;
constexpr int ANGULO_DER = 30;

// Variables para control "No Bloqueante"
int anguloActual = ANGULO_CEN;
int direccion = 1; // 1 para aumentar, -1 para disminuir
unsigned long tiempoPrevio = 0;
const int intervaloServo = 40; // Tiempo entre cada grado (ms)

void setup() {
  ::Serial.begin(9600);
  
  // Inicializar Radar
  myServo.attach(PIN_SERVO);
  pinMode(PIN_TRIG, OUTPUT);
  pinMode(PIN_ECHO, INPUT);
  
  // Inicializar Pantalla
  lcd.init();
  lcd.backlight();
  
  myServo.write(ANGULO_CEN);
}

void loop() {
  // 1. AQUÍ VA EL CÓDIGO DE TUS MOTORES O INVESTIGACIÓN
  // Ejemplo: moverRover(); 

  // 2. GESTIÓN DEL RADAR (Sin detener el programa)
  unsigned long tiempoActual = millis();

  if (tiempoActual - tiempoPrevio >= intervaloServo) {
    tiempoPrevio = tiempoActual;

    // Actualizar ángulo
    anguloActual += direccion;
    myServo.write(anguloActual);

    // Cambiar dirección si llegamos a los límites
    if (anguloActual >= ANGULO_IZQ || anguloActual <= ANGULO_DER) {
      direccion *= -1; 
    }

    // 3. MEDIR DISTANCIA
    int d = obtenerDistanciaRapida();
    if (d != -1) {
      actualizarPantallaYSerie(anguloActual, d);
    }
  }
}

// Función de lectura rápida
int obtenerDistanciaRapida() {
  digitalWrite(PIN_TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(PIN_TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(PIN_TRIG, LOW);

  long dpc = pulseIn(PIN_ECHO, HIGH, 15000); // Timeout corto para no frenar
  if (dpc == 0) return -1;
  
  int cm = dpc * 0.034 / 2;
  return (cm > 30) ? -1 : cm;
}

void actualizarPantallaYSerie(int ang, int dist) {
  lcd.setCursor(0,0);
  lcd.print("Radar: "); lcd.print(ang); lcd.print("    "); // Espacios para limpiar restos
  lcd.setCursor(0,1);
  lcd.print("Dist: "); lcd.print(dist); lcd.print("cm   ");
}