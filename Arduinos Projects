   327	// 8) SETUP Y LOOP PRINCIPAL
   328	// -----------------------------------------------------------------------------
   329	
   330	void setup() {
   331	  // Puerto serie para depuración desde PC
   332	  Serial.begin(115200);
   333	
   334	  // Configuración de pines del puente H
   335	  pinMode(PIN_IN1, OUTPUT);
   336	  pinMode(PIN_IN2, OUTPUT);
   337	  pinMode(PIN_IN3, OUTPUT);
   338	  pinMode(PIN_IN4, OUTPUT);
   339	
   340	  // Configuración del ultrasónico
   341	  pinMode(PIN_TRIG, OUTPUT);
   342	  pinMode(PIN_ECHO, INPUT);
   343	
   344	  // PWM (LEDC) en ESP32 para ENA/ENB
   345	  ledcSetup(PWM_CH_ENA, PWM_FREQ, PWM_RESOLUTION);
   346	  ledcSetup(PWM_CH_ENB, PWM_FREQ, PWM_RESOLUTION);
   347	  ledcAttachPin(PIN_ENA, PWM_CH_ENA);
   348	  ledcAttachPin(PIN_ENB, PWM_CH_ENB);
   349	
   350	  // Inicialización del servo
   351	  // min/max microsegundos típicos para mayor compatibilidad
   352	  sensorServo.setPeriodHertz(50);
   353	  sensorServo.attach(PIN_SERVO, 500, 2400);
   354	  sensorServo.write(ANGULO_CEN);
   355	
   356	  // Inicialización Bluetooth con nombre visible en el celular
   357	  BT.begin("AREO_ROVER_BT");
   358	
   359	  // Estado seguro al arrancar
   360	  detenerMotores();
   361	
   362	  Serial.println("Rover listo. Conecta por Bluetooth a: AREO_ROVER_BT");
   363	  BT.println("Rover listo. Comandos: F B L R S A y 0..9");
   364	}
   365	
   366	void loop() {
   367	  // 1) Leer comandos si llegan por Bluetooth
   368	  while (BT.available() > 0) {
   369	    char cmd = BT.read();
   370	
   371	    // Ignoramos saltos de línea para evitar ruido de apps terminal
   372	    if (cmd == '\n' || cmd == '\r') {
   373	      continue;
   374	    }
   375	
   376	    procesarComando(cmd);
   377	  }
   378	
   379	  // 2) Si modo automático está activo, ejecutamos navegación periódicamente
   380	  if (modoAutomatico) {
   381	    navegarAutomatico();
   382	  }
   383	
   384	  // Pequeño retardo para no saturar CPU
   385	  delay(30);
   386	}
