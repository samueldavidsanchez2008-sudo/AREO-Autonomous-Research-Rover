   161	// -----------------------------------------------------------------------------
   162	// 5) FUNCIONES DEL SENSOR ULTRASÓNICO
   163	// -----------------------------------------------------------------------------
   164	
   165	/*
   166	  medirDistanciaCM:
   167	  1) Enviamos pulso corto por TRIG.
   168	  2) Medimos ancho del pulso en ECHO con pulseIn.
   169	  3) Convertimos tiempo a distancia.
   170	
   171	  Fórmula aproximada:
   172	  distancia_cm = tiempo_us * 0.0343 / 2
   173	  (porque el sonido va y regresa)
   174	*/
   175	float medirDistanciaCM() {
   176	  // Aseguramos TRIG en LOW brevemente
   177	  digitalWrite(PIN_TRIG, LOW);
   178	  delayMicroseconds(3);
   179	
   180	  // Pulso de 10us para disparar medición
   181	  digitalWrite(PIN_TRIG, HIGH);
   182	  delayMicroseconds(10);
   183	  digitalWrite(PIN_TRIG, LOW);
   184	
   185	  // Timeout de 25ms (≈4m), evita bloqueos largos si no hay eco
   186	  unsigned long duracion = pulseIn(PIN_ECHO, HIGH, 25000UL);
   187	
   188	  // Si no hubo eco (duración 0), retornamos valor grande
   189	  if (duracion == 0) {
   190	    return 999.0;
   191	  }
   192	
   193	  return (duracion * 0.0343f) / 2.0f;
   194	}
   195	
   196	/*
   197	  medirEnAngulo:
   198	  - Mueve servo al ángulo solicitado.
   199	  - Espera un poco para que el servo se estabilice.
   200	  - Toma medición de distancia.
   201	*/
   202	float medirEnAngulo(int angulo) {
   203	  sensorServo.write(angulo);
   204	  delay(250); // tiempo de asentamiento mecánico del servo
   205	  return medirDistanciaCM();
   206	}
   207	
   208	// -----------------------------------------------------------------------------
   209	// 6) LÓGICA DE EVASIÓN BÁSICA DE OBSTÁCULOS
   210	// -----------------------------------------------------------------------------
   211	
   212	/*
   213	  escogerDireccionLibre:
   214	  Compara distancias izquierda y derecha y retorna:
   215	  - 'L' si conviene girar a la izquierda
   216	  - 'R' si conviene girar a la derecha
   217	*/
   218	char escogerDireccionLibre() {
   219	  float dIzq = medirEnAngulo(ANGULO_IZQ);
   220	  float dDer = medirEnAngulo(ANGULO_DER);
   221	
   222	  // Volvemos el servo al centro para no dejarlo desalineado
   223	  sensorServo.write(ANGULO_CEN);
   224	
   225	  BT.printf("Escaneo -> Izq: %.1f cm, Der: %.1f cm\n", dIzq, dDer);
   226	
   227	  return (dIzq >= dDer) ? 'L' : 'R';
   228	}
   229	
   230	/*
   231	  navegarAutomatico:
   232	  - Si frente libre: avanza.
   233	  - Si obstáculo cercano: se detiene, retrocede un poco y gira al lado más libre.
   234	*/
   235	void navegarAutomatico() {
   236	  float frente = medirEnAngulo(ANGULO_CEN);
   237	  BT.printf("Frente: %.1f cm\n", frente);
   238	
   239	  if (frente > DISTANCIA_SEGURA_CM) {
   240	    avanzar(velocidadBase);
   241	    return;
   242	  }
   243	
   244	  // Obstáculo detectado
   245	  detenerMotores();
   246	  delay(200);
   247	  retroceder(150);
   248	  delay(300);
   249	  detenerMotores();
   250	  delay(150);
   251	
   252	  char dir = escogerDireccionLibre();
   253	  if (dir == 'L') {
   254	    girarIzquierda(160);
   255	  } else {
   256	    girarDerecha(160);
   257	  }
   258	
   259	  delay(350);
   260	  detenerMotores();
   261	}
