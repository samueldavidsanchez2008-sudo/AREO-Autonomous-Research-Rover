#include <Arduino.h> // Esta libreria sirve para la mayoría de las funciones básicas de Arduino/ESP32
#include <BluetoothSerial.h> // Bluetooth clásico (SPP) en ESP32, me permite comunicación con celular
#include <ESP32Servo.h>      // Librería para controlar servos en ESP32
