// 5) TELEMETRÍA DE DISTANCIA CON ULTRASÓNICO Y SERVO (RADAR)
/*
medirDistanciaCM:
1) Enviamos pulso corto por TRIG.
2) Medimos ancho del pulso en ECHO con pulseIn.
3) Convertimos tiempo a distancia.
Fórmula aproximada:
distancia_cm = tiempo_us * 0.0343 / 2 OJO: Aquí hay que hacer un re-Calculo preciso del valor, debido a que la velocidad del sonido puede variar con la temperatura y la humedad
(porque el sonido va y regresa)
*/
float medirDistanciaCM() {
// Aseguramos TRIG en LOW brevemente
  digitalWrite(PIN_TRIG, LOW);
  delayMicroseconds(3);
// Pulso de 10us para disparar medición
  digitalWrite(PIN_TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(PIN_TRIG, LOW);
// Timeout de 25ms (≈4m), evita bloqueos largos si no hay eco
unsigned long duracion = pulseIn(PIN_ECHO, HIGH, 25000UL);
// Si no hubo eco (duración 0), retornamos valor grande
  if (duracion == 0) {
    return 999.0;
     }
	  return (duracion * 0.0343f) / 2.0f;
	}	
