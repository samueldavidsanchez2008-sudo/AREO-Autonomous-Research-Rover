   264	// 7) PROCESAMIENTO DE COMANDOS DESDE CELULAR
   265	// -----------------------------------------------------------------------------
   266	
   267	/*
   268	  Comandos soportados por Bluetooth:
   269	  - F: Forward (avanzar)
   270	  - B: Backward (retroceder)
   271	  - L: Left (girar izquierda)
   272	  - R: Right (girar derecha)
   273	  - S: Stop (detener)
   274	  - A: Alternar modo automático ON/OFF
   275	  - 0..9: Ajustar velocidad base (0=0, 9=255 aprox.)
   276	*/
   277	void procesarComando(char cmd) {
   278	  // Si llega comando manual de movimiento, desactivamos automático
   279	  if (cmd == 'F' || cmd == 'B' || cmd == 'L' || cmd == 'R' || cmd == 'S') {
   280	    modoAutomatico = false;
   281	  }
   282	
   283	  switch (cmd) {
   284	    case 'F':
   285	      avanzar(velocidadBase);
   286	      BT.println("Manual: avanzar");
   287	      break;
   288	
   289	    case 'B':
   290	      retroceder(velocidadBase);
   291	      BT.println("Manual: retroceder");
   292	      break;
   293	
   294	    case 'L':
   295	      girarIzquierda(velocidadBase);
   296	      BT.println("Manual: izquierda");
   297	      break;
   298	
   299	    case 'R':
   300	      girarDerecha(velocidadBase);
   301	      BT.println("Manual: derecha");
   302	      break;
   303	
   304	    case 'S':
   305	      detenerMotores();
   306	      BT.println("Manual: stop");
   307	      break;
   308	
   309	    case 'A':
   310	      modoAutomatico = !modoAutomatico;
   311	      detenerMotores();
   312	      BT.printf("Modo automatico: %s\n", modoAutomatico ? "ON" : "OFF");
   313	      break;
   314	
   315	    default:
   316	      // Control de velocidad con caracteres '0'...'9'
   317	      if (cmd >= '0' && cmd <= '9') {
   318	        int nivel = cmd - '0';
   319	        velocidadBase = map(nivel, 0, 9, 0, 255);
   320	        BT.printf("Velocidad base: %d\n", velocidadBase);
   321	      }
   322	      break;
   323	  }
   324	}
